# Copy this file to .env for local/prod-like runs
# Windows PowerShell:
#   Copy-Item .env.example .env

# InfluxDB bootstrap
INFLUXDB_INIT_USERNAME=omni
INFLUXDB_INIT_PASSWORD=change_me_in_prod
INFLUXDB_ORG=omnivigil
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=change_me_in_prod_token
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_CLI_CONFIG_NAME=omnivigil

# Auth service
JWT_SECRET=change_me_strong_jwt_secret

# PostgreSQL maintenance DB
MAINT_POSTGRES_USER=omni
MAINT_POSTGRES_PASSWORD=change_me_maintenance_db_password
MAINT_POSTGRES_DB=maintenance
REQUIRE_REGISTERED_MACHINE=true

# Machine registry live status
MACHINE_OFFLINE_AFTER_MINUTES=5
MACHINE_TOUCH_TIMEOUT_SECONDS=2

# PostgreSQL auth DB
AUTH_POSTGRES_USER=omni
AUTH_POSTGRES_PASSWORD=change_me_auth_db_password
AUTH_POSTGRES_DB=auth

# PostgreSQL AI Engine DB
AI_POSTGRES_USER=omni
AI_POSTGRES_PASSWORD=change_me_ai_db_password
AI_POSTGRES_DB=ai_engine

# MS3 AI Engine
# Set false only when you want the fast threshold-only demo worker.
MS3_INSTALL_ML=true
MS3_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
MS3_GPU_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu126
AI_ENABLE_WORKER_INFERENCE=true
AI_WORKER_RESULT_TIMEOUT_SECONDS=300
AI_WORKER_TASK_TIME_LIMIT_SECONDS=900
AI_ENGINE_TIMEOUT_SECONDS=300
CHRONOS_MODEL_ID=Stalemartyr/chronos-finetuned
CHRONOS_DEVICE=auto
