# Copy this file to .env for local/prod-like runs
# Windows PowerShell:
#   Copy-Item .env.example .env

# InfluxDB bootstrap
INFLUXDB_INIT_USERNAME=omni
INFLUXDB_INIT_PASSWORD=change_me_in_prod
INFLUXDB_ORG=omnivigil
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=change_me_in_prod_token
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_CLI_CONFIG_NAME=omnivigil

# Auth service
JWT_SECRET=change_me_strong_jwt_secret

# PostgreSQL maintenance DB
MAINT_POSTGRES_USER=omni
MAINT_POSTGRES_PASSWORD=change_me_maintenance_db_password
MAINT_POSTGRES_DB=maintenance

# PostgreSQL auth DB
AUTH_POSTGRES_USER=omni
AUTH_POSTGRES_PASSWORD=change_me_auth_db_password
AUTH_POSTGRES_DB=auth
