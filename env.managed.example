# Managed mode env (external MQTT/Redis/Influx/Postgres)
# Copy to .env.managed and fill with real values from your platform team.
# IMPORTANT: do not use localhost values in this file.

# =========================
# Shared security settings
# =========================
JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
INTERNAL_SERVICE_KEY=REPLACE_WITH_INTERNAL_SHARED_KEY

# =========================
# External MQTT
# =========================
MQTT_BROKER=YOUR_MANAGED_MQTT_HOSTNAME
MQTT_PORT=1883
MQTT_TOPIC=omnivigil/telemetry
MQTT_QOS=1

# =========================
# External Redis
# =========================
REDIS_URL=rediss://YOUR_MANAGED_REDIS_HOST:6379/0
REDIS_EVENT_CHANNEL=anomaly_detected
MS3_JOB_PREFIX=ms3:job

# =========================
# External InfluxDB
# =========================
INFLUXDB_URL=https://YOUR_MANAGED_INFLUX_HOST
INFLUXDB_TOKEN=REPLACE_WITH_INFLUX_TOKEN
INFLUXDB_ORG=omnivigil
INFLUXDB_BUCKET=telemetry

# =========================
# External PostgreSQL
# =========================
# Auth DB (MS1)
POSTGRES_URL_AUTH=postgresql://auth_user:auth_password@YOUR_AUTH_DB_HOST:5432/auth_db

# Alert audit DB (MS4)
ALERT_POSTGRES_URL=postgresql://alert_user:alert_password@YOUR_ALERT_DB_HOST:5432/alert_db

# Maintenance DB (MS5)
POSTGRES_URL_MAINT=postgresql://maint_user:maint_password@YOUR_MAINT_DB_HOST:5432/maintenance_db

# =========================
# Internal service URLs
# =========================
MS1_AUTH_URL=http://ms1-auth:8001
AI_ENGINE_URL=http://ms3-ai-engine:8003

# =========================
# Simulator tuning (optional)
# =========================
INTERVAL_OPTIONS_SEC=1,2,3,4,5
ANOMALY_RATE=0.04
MACHINE_COUNT=5
NETWORK_DROP_RATE=0.03
NETWORK_DROP_DURATION_SEC=8
MANUAL_TRIGGER_FILE=/tmp/force_anomaly
